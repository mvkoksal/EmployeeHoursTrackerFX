<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.timetracker.demo.controllers.dashboardController"
            style="-fx-background-color: #F2F8F7;
            -fx-padding: 0;
            -fx-background-insets: 0">

    <!-- Sidebar -->
    <VBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          prefWidth="384"
          spacing="20"
          style="-fx-background-color: #FFFFFF; -fx-snap-to-pixel: true;">

        <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
        </padding>

        <Label text="Time Tracker FX"
               style="-fx-font-size: 30;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans' ">
                <VBox.margin>
                    <Insets bottom="30"/>
                </VBox.margin>
        </Label>

        <Label text="Dashboard"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>

        <Label text="Log Hours"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>

        <Label text="Schedule"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>

        <Label text="Payment History"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>

        <Label text="Contact Employer"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>

        <!-- spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <Label text="Your Account"
               maxWidth="Infinity"
               style="-fx-font-size: 20;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans';
                    -fx-text-fill: #0F2422;
                    -fx-border-color: #C8E0DC;
                    -fx-cursor: hand;
                    -fx-padding: 20"/>
    </VBox>

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="384"
          AnchorPane.rightAnchor="370"
          spacing="20"
          style="-fx-background-color: #F2F8F7; -fx-snap-to-pixel: true;">

        <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
        </padding>

        <Label fx:id="welcomingText" text="Hello, Meryem!"
               style="-fx-font-size: 40;
                    -fx-font-weight: bold;
                    -fx-font-family: 'Plus Jakarta Sans' ">
                <VBox.margin>
                    <Insets bottom="30"/>
                </VBox.margin>
        </Label>

        <VBox style="-fx-background-color: #FFFFFF; -fx-snap-to-pixel: true;">
            <Label text="Lorem ipsum"
                   style="-fx-font-size: 50"/>
            <Label text="Lorem ipsum"
                   style="-fx-font-size: 50"/>
            <Label text="Lorem ipsum"
                   style="-fx-font-size: 50"/>
        </VBox>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <rowConstraints>
                <RowConstraints prefHeight="150"/>
                <RowConstraints prefHeight="150"/>
            </rowConstraints>

            <Label text="LOG HOURS" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                  -fx-font-family: 'Plus Jakarta Sans';
                  -fx-text-fill: #0F2422;
                  -fx-border-color: #C8E0DC;
                  -fx-background-color: white;
                  -fx-border-radius: 8; -fx-background-radius: 8;
                  -fx-alignment: center;
                  -fx-cursor: hand;"/>

            <Label text="SCHEDULE" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                  -fx-font-family: 'Plus Jakarta Sans';
                  -fx-text-fill: #0F2422;
                  -fx-border-color: #C8E0DC;
                  -fx-background-color: white;
                  -fx-border-radius: 8; -fx-background-radius: 8;
                  -fx-alignment: center;
                  -fx-cursor: hand;"/>

            <Label text="PAYMENT HISTORY" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                  -fx-font-family: 'Plus Jakarta Sans';
                  -fx-text-fill: #0F2422;
                  -fx-border-color: #C8E0DC;
                  -fx-background-color: white;
                  -fx-border-radius: 8; -fx-background-radius: 8;
                  -fx-alignment: center;
                  -fx-cursor: hand;"/>

            <Label text="CONTACT EMPLOYER" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                  -fx-font-family: 'Plus Jakarta Sans';
                  -fx-text-fill: #0F2422;
                  -fx-border-color: #C8E0DC;
                  -fx-background-color: white;
                  -fx-border-radius: 8; -fx-background-radius: 8;
                  -fx-alignment: center;
                  -fx-cursor: hand;"/>
        </GridPane>
    </VBox>

    <VBox AnchorPane.topAnchor="50"
          AnchorPane.rightAnchor="50"
          prefWidth="300"
          spacing="20"
          style="-fx-background-color: #FFFFFF; -fx-snap-to-pixel: true;">

        <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
        </padding>

        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>
        <Label text="Lorem ipsum"
               style="-fx-font-size: 20"/>

    </VBox>
</AnchorPane>

